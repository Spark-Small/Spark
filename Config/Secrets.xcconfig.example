// Copy to Secrets.xcconfig (gitignored) for local/staging API endpoints.
//   cp Config/Secrets.xcconfig.example Config/Secrets.xcconfig
// See docs/STAGING.md and docs/API_CONTRACT.md.
// Non-mock host → CompositionRoot wires Live* repositories.
//
// Staging — CloudBase HTTP 云函数 (spark-api MVP, docs/API_CONTRACT.md):
// SPARK_API_BASE_URL = https://ais-d1gab0emob99361a0.service.tcloudbase.com
//
// Staging (other team host):
// SPARK_API_BASE_URL = https://api.staging.spark.app
//
// Production (Release builds only — use CI or local override, never commit secrets):
// SPARK_API_BASE_URL = https://api.spark.app
//
// Paid Apple Developer Program only (Push + Universal Links; personal teams cannot use these):
// CODE_SIGN_ENTITLEMENTS = Config/Spark.entitlements
// SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) SPARK_ENABLE_PUSH
